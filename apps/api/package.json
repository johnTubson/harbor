{
  "name": "@harbor/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "echo 'lint api'",
    "test": "vitest run",
    "db:migrate": "prisma migrate dev && prisma generate",
